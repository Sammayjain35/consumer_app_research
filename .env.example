# Gemini (for Meta ads video analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Sensor Tower (app intelligence — downloads, revenue, rankings)
SENSOR_TOWER_API_KEY=your_sensor_tower_api_key_here

# YouTube Data API v3 (for youtube.py)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit API (for reddit.py — create app at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=ResearchBot/1.0
